{
	"name": "codex-explain",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"main": ".electron/main.js",
	"description": "A local, diff-focused IDE for understanding Codex-authored changes.",
	"scripts": {
		"dev": "node scripts/dev.mjs",
		"dev:web": "vite dev --host 127.0.0.1",
		"build": "npm run build:renderer && npm run build:electron",
		"build:renderer": "vite build",
		"build:electron": "node scripts/build-electron.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc -p tsconfig.electron.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "npm run build && playwright test",
		"start": "npm run build && electron .",
		"package": "npm run build && electron-forge package",
		"make": "npm run build && electron-forge make"
	},
	"devDependencies": {
		"@electron-forge/cli": "^7.11.2",
		"@electron-forge/maker-dmg": "^7.11.2",
		"@electron-forge/maker-zip": "^7.11.2",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "24",
		"@vitest/browser-playwright": "^4.1.8",
		"electron": "43.1.0",
		"esbuild": "^0.28.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@codemirror/language": "^6.12.4",
		"@codemirror/language-data": "^6.5.2",
		"@codemirror/merge": "^6.12.2",
		"@codemirror/search": "^6.7.1",
		"@codemirror/state": "^6.7.1",
		"@codemirror/view": "^6.43.6",
		"@lucide/svelte": "^1.24.0",
		"@openai/codex": "0.144.1",
		"@openai/codex-sdk": "0.144.1",
		"kokoro-js": "^1.2.1",
		"zod": "^4.4.3"
	}
}
