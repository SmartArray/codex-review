{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"types": ["node", "electron"]
	},
	"include": ["electron/**/*.ts", "src/lib/shared/**/*.ts"]
}
